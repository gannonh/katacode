#!/usr/bin/env sh
set -e

# Auto-format staged files (including markdown) so commits pass `vp check` in CI.
formatted=$(git diff --cached --name-only --diff-filter=ACM |
  grep -E '\.(md|markdown|ts|tsx|js|jsx|mjs|cjs|json|html|css|yaml|yml)$' || true)

if [ -n "$formatted" ]; then
  # shellcheck disable=SC2086
  vp fmt --write $formatted
  git update-index --again
fi
