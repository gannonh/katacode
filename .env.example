# Optional: Kata Code Connect source builds
# Leave these unset to disable optional Connect features in local source builds.
# Release builds inject their public values at build time. Do not add server-side
# secrets to this file.

# Get these from the Clerk Dashboard under API keys, JWT templates, and OAuth applications.
# KATACODE_CLERK_PUBLISHABLE_KEY=pk_test_...
# KATACODE_CLERK_JWT_TEMPLATE=kata-relay
# KATACODE_CLERK_CLI_OAUTH_CLIENT_ID=oauthapp_...

# Get this from your relay deployment. `infra/relay` deploys update it automatically.
# KATACODE_RELAY_URL=https://relay.example.com

# Public, ingest-only mobile OpenTelemetry configuration.
# KATACODE_MOBILE_OTLP_TRACES_URL=https://api.axiom.co/v1/traces
# KATACODE_MOBILE_OTLP_TRACES_DATASET=kata-code-mobile-traces-dev
# KATACODE_MOBILE_OTLP_TRACES_TOKEN=xaat-...

# Local Electron E2E (macOS only, not used in CI). Copy values into .env.local.
# See e2e/README.md for full setup.

# Clerk (@clerk/testing + signed-in flows). Publishable key aliases above also work.
# CLERK_SECRET_KEY=sk_test_...

# Google test user for Clerk OAuth UI automation.
# KATACODE_E2E_GOOGLE_EMAIL=test-user@example.com
# KATACODE_E2E_GOOGLE_PASSWORD=

# Deterministic @agent tests (real provider; no mocks).
# KATACODE_E2E_AGENT_PROVIDER=openai
# KATACODE_E2E_AGENT_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Release-target E2E (desktop-release project).
# KATACODE_E2E_RELEASE_APP=/Applications/Kata Code.app

# Runner tuning (optional).
# KATACODE_E2E_WORKERS=1
# KATACODE_E2E_VIDEO=1
