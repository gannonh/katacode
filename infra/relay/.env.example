# Kata Code Connect relay — local source of truth for production deploy credentials.
# Copy to infra/relay/.env (gitignored), fill every value, then run:
#   node infra/relay/scripts/run-credential-smoke.ts
#   node infra/relay/scripts/sync-github-config.ts --dry-run
#   node infra/relay/scripts/sync-github-config.ts
#   node scripts/sync-client-env-from-relay.ts

# --- Cloudflare ---
# Dashboard: Workers & Pages > Overview > Account ID (right sidebar)
CLOUDFLARE_ACCOUNT_ID=
# Dashboard: My Profile > API Tokens > Create Token (start from "Edit Cloudflare Workers")
CLOUDFLARE_API_TOKEN=
# Dashboard: Websites > Add site (zone apex, e.g. connect.kata.sh)
RELAY_API_ZONE_NAME=
# Dashboard: Websites > Add site (tunnel hostnames, e.g. tunnels.kata.sh)
RELAY_TUNNEL_ZONE_NAME=
# Optional override when relay hostname should not be relay.<RELAY_API_ZONE_NAME>
# RELAY_DOMAIN=relay.connect.kata.sh

# --- PlanetScale ---
# Dashboard: Organization settings > organization name
PLANETSCALE_ORGANIZATION=
# Dashboard: Settings > Service tokens > Create service token
PLANETSCALE_API_TOKEN_ID=
PLANETSCALE_API_TOKEN=

# --- Axiom ---
# Dashboard: Settings > Organization > Organization ID
AXIOM_ORG_ID=
# Dashboard: Settings > API tokens > Create token (ingest permissions)
AXIOM_TOKEN=

# --- Clerk ---
# Dashboard: API keys
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Dashboard: JWT templates > create template named kata-relay with {"aud":"kata-code-relay"}
CLERK_JWT_TEMPLATE=kata-relay
CLERK_JWT_AUDIENCE=kata-code-relay
# Dashboard: OAuth applications > public client for katacode connect CLI
CLERK_CLI_OAUTH_CLIENT_ID=
# Dashboard: Users > dedicated approved beta user for deploy smoke (user_...)
CLERK_SMOKE_USER_ID=

# --- Apple Push Notification service ---
# Apple Developer: Keys > create APNs key; use sandbox for pre-prod, production for prod relay
APNS_ENVIRONMENT=sandbox
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
# PEM contents; in .env use literal newlines or \n escapes
APNS_PRIVATE_KEY=
